# Re-include the documentation SITE source. The repo-root .gitignore has a
# generic `docs/` rule (intended for downloaded API docs) that would otherwise
# exclude these — they are first-class source for the docs site and must ship.
!src/content/docs/
!src/content/docs/**
!src/components/docs/
!src/components/docs/**
!src/pages/docs/
!src/pages/docs/**
