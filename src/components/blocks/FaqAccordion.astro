---
// =====================================================================
// FaqAccordion — accessible expand/collapse Q&A for objection handling.
// Native <button> headers (keyboard-operable) drive aria-expanded and a
// linked region via aria-controls. Toggling is handled by one guarded,
// document-level delegated listener so it survives <ClientRouter /> swaps
// and never double-binds. Animation respects prefers-reduced-motion.
// =====================================================================
export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  eyebrow?: string;
  heading?: string;
  items: FaqItem[];
  headingId?: string;
  /** Unique-ish id base so multiple accordions don't collide. */
  idBase?: string;
}

const {
  eyebrow,
  heading,
  items,
  headingId = "faq-heading",
  idBase = "faq",
} = Astro.props;
---

<section class="section faq" aria-labelledby={heading ? headingId : undefined}>
  <div class="container container--narrow">
    {
      (eyebrow || heading) && (
        <header class="faq__head">
          {eyebrow && <p class="eyebrow reveal">{eyebrow}</p>}
          {heading && (
            <h2 class="display display--lg faq__heading reveal" id={headingId} data-reveal-delay="0.05">
              {heading}
            </h2>
          )}
        </header>
      )
    }

    <ul class="faq__list" data-faq>
      {
        items.map((item, i) => {
          const btnId = `${idBase}-q-${i}`;
          const panelId = `${idBase}-a-${i}`;
          return (
            <li class="faq__item reveal" data-reveal-delay={(0.03 + (i % 4) * 0.03).toFixed(2)}>
              <h3 class="faq__q-wrap">
                <button
                  class="faq__q"
                  type="button"
                  id={btnId}
                  aria-expanded="false"
                  aria-controls={panelId}
                  data-faq-toggle
                >
                  <span class="faq__q-text">{item.question}</span>
                  <span class="faq__icon" aria-hidden="true" />
                </button>
              </h3>
              <div class="faq__panel" id={panelId} role="region" aria-labelledby={btnId} hidden>
                <div class="faq__answer">
                  <p>{item.answer}</p>
                </div>
              </div>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .faq__head {
    max-width: 40ch;
    margin-bottom: clamp(36px, 4.4vw, 56px);
  }
  .faq__heading {
    margin-top: 0.5em;
  }

  .faq__list {
    border-top: 1px solid var(--rule);
  }
  .faq__item {
    border-bottom: 1px solid var(--rule);
  }
  .faq__q-wrap {
    margin: 0;
    font-weight: inherit;
  }
  .faq__q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(16px, 3vw, 40px);
    padding: clamp(22px, 2.6vw, 32px) 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
    color: var(--char);
    transition: color var(--t-fast) var(--ease);
  }
  .faq__q:hover,
  .faq__q:focus-visible {
    color: var(--gold-deep);
  }
  .faq__q-text {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(1.2rem, 1.7vw, 1.5rem);
    line-height: 1.18;
  }

  /* +/- icon */
  .faq__icon {
    position: relative;
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
  }
  .faq__icon::before,
  .faq__icon::after {
    content: "";
    position: absolute;
    inset: 0;
    margin: auto;
    background: var(--gold-deep);
    transition: transform var(--t-base) var(--ease), opacity var(--t-base) var(--ease);
  }
  .faq__icon::before {
    width: 100%;
    height: 1.5px;
  }
  .faq__icon::after {
    width: 1.5px;
    height: 100%;
  }
  .faq__q[aria-expanded="true"] .faq__icon::after {
    transform: rotate(90deg);
    opacity: 0;
  }

  /* Panel: animated open via grid-template-rows when motion is allowed. */
  .faq__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--t-base) var(--ease);
  }
  .faq__panel[hidden] {
    display: none;
  }
  .faq__panel.is-open {
    grid-template-rows: 1fr;
  }
  .faq__answer {
    overflow: hidden;
    min-height: 0;
  }
  .faq__answer p {
    margin: 0;
    padding-bottom: clamp(22px, 2.6vw, 32px);
    max-width: 64ch;
    font-family: var(--serif-body);
    font-size: var(--t-body);
    line-height: 1.6;
    color: var(--graphite);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq__panel {
      transition: none;
    }
  }
</style>

<script>
  // One guarded, document-level delegated listener so the accordion keeps
  // working across <ClientRouter /> swaps (where this <section> is replaced)
  // and never double-binds if the module is re-evaluated.
  const w = window as typeof window & { __ggFaqInit?: boolean };
  if (!w.__ggFaqInit) {
    w.__ggFaqInit = true;

    document.addEventListener("click", (e) => {
      const target = e.target as Element | null;
      const btn = target?.closest<HTMLButtonElement>("[data-faq-toggle]");
      if (!btn) return;

      const panelId = btn.getAttribute("aria-controls");
      const panel = panelId ? document.getElementById(panelId) : null;
      if (!panel) return;

      const open = btn.getAttribute("aria-expanded") === "true";

      if (open) {
        btn.setAttribute("aria-expanded", "false");
        panel.classList.remove("is-open");
        // Wait for the collapse transition before hiding (so it animates).
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce) {
          panel.hidden = true;
        } else {
          panel.addEventListener(
            "transitionend",
            () => {
              if (btn.getAttribute("aria-expanded") === "false") panel.hidden = true;
            },
            { once: true },
          );
        }
      } else {
        btn.setAttribute("aria-expanded", "true");
        panel.hidden = false;
        // Force a reflow so the grid-rows transition runs from 0fr → 1fr.
        void panel.offsetHeight;
        panel.classList.add("is-open");
      }
    });
  }
</script>
