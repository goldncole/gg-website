---
// =====================================================================
// PageHero — standardized inner-page hero.
// Eyebrow + display title + lede + optional badges + optional CTAs and
// optional image. Two layouts:
//   • no image  → text-led, left-aligned, faint gold-icon watermark
//   • image     → split (text left, rounded image right)
// Always pads the top so the H1 clears the fixed site header.
// =====================================================================
export interface HeroCta {
  label: string;
  href: string;
}

export interface HeroImage {
  src: string;
  alt: string;
}

import { imgProps } from "../../lib/img";

export interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  /** Small uppercase pills under the title (e.g. token type / ticker). */
  badges?: string[];
  /** Inline trust/fact chips below the actions. */
  meta?: string[];
  image?: HeroImage;
  primaryCta?: HeroCta;
  secondaryCta?: HeroCta;
  /** Heading id, for aria-labelledby on the wrapping <section>. */
  headingId?: string;
}

const {
  eyebrow,
  title,
  lede,
  badges = [],
  meta = [],
  image,
  primaryCta,
  secondaryCta,
  headingId = "page-hero-heading",
} = Astro.props;

const hasImage = Boolean(image);
// Split layout: image is ~half the container on desktop, full-width ≤900px.
const heroImg = image ? imgProps(image.src, "(max-width: 900px) 100vw, 50vw") : null;
---

<section
  class:list={["section", "page-hero", { "page-hero--split": hasImage }]}
  aria-labelledby={headingId}
>
  {
    !hasImage && (
      <img
        class="page-hero__watermark"
        src="/images/gold-icon.webp"
        alt=""
        aria-hidden="true"
        loading="lazy"
        decoding="async"
      />
    )
  }

  <div class="container page-hero__inner">
    <div class="page-hero__text">
      {eyebrow && <p class="eyebrow reveal">{eyebrow}</p>}

      <h1 class="display display--xl page-hero__title reveal" id={headingId} data-reveal-delay="0.05">
        {title}
      </h1>

      {
        badges.length > 0 && (
          <ul class="page-hero__badges reveal" data-reveal-delay="0.08" role="list">
            {badges.map((b) => (
              <li class="page-hero__badge">{b}</li>
            ))}
          </ul>
        )
      }

      {lede && <p class="page-hero__lede reveal" data-reveal-delay="0.1">{lede}</p>}

      {
        (primaryCta || secondaryCta) && (
          <div class="page-hero__actions reveal" data-reveal-delay="0.16">
            {primaryCta && (
              <a class="cta--box" href={primaryCta.href}>
                {primaryCta.label}
              </a>
            )}
            {secondaryCta && (
              <a class="cta" href={secondaryCta.href}>
                {secondaryCta.label} &rarr;
              </a>
            )}
          </div>
        )
      }

      {
        meta.length > 0 && (
          <ul class="page-hero__meta reveal" data-reveal-delay="0.2" role="list">
            {meta.map((m) => (
              <li>{m}</li>
            ))}
          </ul>
        )
      }
    </div>

    {
      hasImage && (
        <figure class="page-hero__media reveal" data-reveal-delay="0.12">
          <img {...heroImg!} alt={image!.alt} loading="eager" fetchpriority="high" decoding="async" />
        </figure>
      )
    }
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    /* clear the fixed site header */
    padding-top: clamp(140px, 18vh, 220px);
  }
  .page-hero__inner {
    position: relative;
    z-index: 1;
  }

  .page-hero__watermark {
    position: absolute;
    z-index: 0;
    top: 50%;
    right: clamp(-120px, -4vw, -40px);
    width: min(48vw, 560px);
    transform: translateY(-50%);
    opacity: 0.06;
    filter: grayscale(1) brightness(0.4);
    pointer-events: none;
  }

  .page-hero__title {
    margin-top: clamp(20px, 2.6vw, 32px);
    max-width: 18ch;
    text-wrap: balance;
  }

  .page-hero__badges {
    margin-top: clamp(20px, 2.4vw, 28px);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6em;
  }
  .page-hero__badge {
    font-family: var(--sans-display);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-deep);
    padding: 7px 14px;
    border: 1px solid var(--rule);
    border-radius: 999px;
  }

  .page-hero__lede {
    margin: clamp(28px, 3.6vw, 44px) 0 0;
    max-width: 62ch;
    font-family: var(--serif-body);
    font-weight: 400;
    font-size: clamp(1.3rem, 1.9vw, 1.7rem);
    line-height: 1.5;
    color: var(--char);
  }

  .page-hero__actions {
    margin-top: clamp(32px, 4vw, 48px);
    display: flex;
    align-items: center;
    gap: clamp(20px, 3vw, 40px);
    flex-wrap: wrap;
  }

  .page-hero__meta {
    margin: clamp(36px, 5vw, 56px) 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6em 1.1em;
    font-family: var(--sans-display);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--graphite);
  }
  .page-hero__meta li {
    position: relative;
  }
  .page-hero__meta li + li::before {
    content: "\00B7";
    margin-right: 1.1em;
    color: var(--gold-deep);
  }

  /* ---- split (with image) ---- */
  .page-hero--split .page-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(32px, 5vw, 80px);
  }
  /* Split heroes carry sentence-length outcome headlines in a half-width
     column, so the homepage-scale display--xl is too large here. Step down to
     the lg size and widen the measure so the line sets in 3–4 clean lines. */
  .page-hero--split .page-hero__title {
    font-size: var(--t-display-lg);
    max-width: 18ch;
  }
  .page-hero__media {
    margin: 0;
    border-radius: var(--radius-img);
    overflow: hidden;
    background: var(--stone);
    aspect-ratio: 4 / 5;
  }
  .page-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .page-hero--split .page-hero__inner {
      grid-template-columns: 1fr;
      gap: clamp(28px, 6vw, 44px);
    }
    .page-hero__media {
      aspect-ratio: 16 / 10;
      order: -1;
    }
    .page-hero--split .page-hero__title {
      max-width: 100%;
    }
  }

  @media (max-width: 720px) {
    .page-hero__title {
      max-width: 100%;
    }
    .page-hero__watermark {
      opacity: 0.04;
    }
    .page-hero__meta {
      flex-direction: column;
      align-items: flex-start;
    }
    .page-hero__meta li + li::before {
      content: none;
    }
  }
</style>
