---
// =====================================================================
// StepFlow — numbered, sequential steps (heading + body + optional image).
// Used for "how it works" mechanisms, "how it works for you", and token
// lifecycles (mint / collateralize / burn / redeem). Steps alternate image side on
// wide screens when images are present.
// =====================================================================
export interface Step {
  title: string;
  body: string;
  image?: { src: string; alt: string };
}

export interface Props {
  eyebrow?: string;
  heading?: string;
  lede?: string;
  steps: Step[];
  /** Show the 01 / 02 / 03 step numerals. Default true. */
  numbered?: boolean;
  headingId?: string;
}

const {
  eyebrow,
  heading,
  lede,
  steps,
  numbered = true,
  headingId = "stepflow-heading",
} = Astro.props;

const anyImages = steps.some((s) => s.image);
---

<section
  class:list={["section", "stepflow", { "stepflow--media": anyImages }]}
  aria-labelledby={heading ? headingId : undefined}
>
  <div class="container">
    {
      (eyebrow || heading || lede) && (
        <header class="stepflow__head">
          {eyebrow && <p class="eyebrow reveal">{eyebrow}</p>}
          {heading && (
            <h2 class="display display--lg stepflow__heading reveal" id={headingId} data-reveal-delay="0.05">
              {heading}
            </h2>
          )}
          {lede && <p class="stepflow__lede reveal" data-reveal-delay="0.1">{lede}</p>}
        </header>
      )
    }

    <ol class="stepflow__list">
      {
        steps.map((step, i) => (
          <li class="step reveal" data-reveal-delay={(0.04 + (i % 3) * 0.04).toFixed(2)}>
            {numbered && (
              <span class="step__no" aria-hidden="true">
                {String(i + 1).padStart(2, "0")}
              </span>
            )}
            <div class="step__text">
              <h3 class="step__title">{step.title}</h3>
              <p class="step__body">{step.body}</p>
            </div>
            {step.image && (
              <figure class="step__media">
                <img src={step.image.src} alt={step.image.alt} loading="lazy" />
              </figure>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .stepflow__head {
    max-width: 46ch;
  }
  .stepflow__heading {
    margin-top: 0.5em;
  }
  .stepflow__lede {
    margin-top: clamp(20px, 2.4vw, 30px);
    max-width: 58ch;
    font-size: var(--t-lede);
    line-height: 1.5;
    color: var(--graphite);
  }

  .stepflow__list {
    margin-top: clamp(48px, 6vw, 84px);
    display: flex;
    flex-direction: column;
  }

  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(20px, 3vw, 48px);
    align-items: start;
    padding-block: clamp(28px, 3.4vw, 44px);
    border-top: 1px solid var(--rule-faint);
  }
  .step:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .step__no {
    font-family: var(--sans-display);
    font-size: clamp(1.1rem, 1.6vw, 1.4rem);
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--gold-deep);
    line-height: 1.1;
  }
  .step__title {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(1.4rem, 2.1vw, 1.9rem);
    line-height: 1.12;
    color: var(--char);
  }
  .step__body {
    margin: clamp(10px, 1.2vw, 16px) 0 0;
    max-width: 64ch;
    font-size: var(--t-body);
    line-height: 1.6;
    color: var(--graphite);
  }

  /* When steps carry imagery, give each step a text column + media column. */
  .stepflow--media .step {
    grid-template-columns: auto minmax(0, 1.1fr) minmax(0, 1fr);
    align-items: center;
  }
  .step__media {
    margin: 0;
    border-radius: var(--radius-img);
    overflow: hidden;
    background: var(--stone);
    aspect-ratio: 16 / 11;
  }
  .step__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 820px) {
    .step,
    .stepflow--media .step {
      grid-template-columns: auto 1fr;
    }
    .step__media {
      grid-column: 1 / -1;
      margin-top: clamp(16px, 3vw, 24px);
      aspect-ratio: 16 / 9;
    }
  }
  @media (max-width: 520px) {
    .step,
    .stepflow--media .step {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
