---
// =====================================================================
// Callout — brand admonition block for docs MDX. Four variants
// (note / tip / warning / important) each with a subtle gold/stone left
// border and an inline SVG icon. Wired into MDX via the `components`
// prop on <Content /> so authors write <Callout type="tip">…</Callout>
// without importing it per file. Styling is light-only and on-brand.
// =====================================================================
type CalloutType = "note" | "tip" | "warning" | "important";

export interface Props {
  type?: CalloutType;
  /** Optional override for the bold label shown in the header row. */
  title?: string;
}

const { type = "note", title } = Astro.props;

const LABELS: Record<CalloutType, string> = {
  note: "Note",
  tip: "Tip",
  warning: "Warning",
  important: "Important",
};

const label = title ?? LABELS[type];
---

<aside class:list={["callout", `callout--${type}`]} role="note" aria-label={label}>
  <span class="callout__icon" aria-hidden="true">
    {type === "note" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M12 11v5"></path>
        <path d="M12 8h.01"></path>
      </svg>
    )}
    {type === "tip" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18h6"></path>
        <path d="M10 21h4"></path>
        <path d="M12 3a6 6 0 0 0-3.6 10.8c.6.45.9.9.96 1.7H14.6c.07-.8.37-1.25.97-1.7A6 6 0 0 0 12 3Z"></path>
      </svg>
    )}
    {type === "warning" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10.3 4.3 2.2 18a2 2 0 0 0 1.7 3h16.2a2 2 0 0 0 1.7-3L13.7 4.3a2 2 0 0 0-3.4 0Z"></path>
        <path d="M12 9v4"></path>
        <path d="M12 17h.01"></path>
      </svg>
    )}
    {type === "important" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3 4 6v6c0 4.5 3.2 7.6 8 9 4.8-1.4 8-4.5 8-9V6l-8-3Z"></path>
        <path d="M12 8v4"></path>
        <path d="M12 16h.01"></path>
      </svg>
    )}
  </span>
  <div class="callout__body">
    <p class="callout__label">{label}</p>
    <div class="callout__content">
      <slot />
    </div>
  </div>
</aside>

<style>
  .callout {
    --callout-accent: var(--stone-warm);
    --callout-tint: rgba(216, 210, 200, 0.16);
    display: flex;
    gap: clamp(12px, 1.4vw, 16px);
    margin: 1.6em 0;
    padding: clamp(16px, 1.6vw, 20px) clamp(18px, 1.8vw, 22px);
    background: var(--callout-tint);
    border: 1px solid var(--rule-faint);
    border-left: 3px solid var(--callout-accent);
    border-radius: 0 var(--radius-img) var(--radius-img) 0;
  }

  .callout--note {
    --callout-accent: var(--stone-warm);
    --callout-tint: rgba(216, 210, 200, 0.18);
  }
  .callout--tip {
    --callout-accent: var(--gold);
    --callout-tint: rgba(198, 161, 91, 0.1);
  }
  .callout--warning {
    --callout-accent: var(--gold-deep);
    --callout-tint: rgba(138, 106, 61, 0.1);
  }
  .callout--important {
    --callout-accent: var(--char);
    --callout-tint: rgba(42, 39, 36, 0.06);
  }

  .callout__icon {
    flex: 0 0 auto;
    width: 22px;
    height: 22px;
    margin-top: 0.1em;
    color: var(--callout-accent);
  }
  .callout--note .callout__icon,
  .callout--important .callout__icon {
    color: var(--gold-deep);
  }
  .callout__icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .callout__body {
    min-width: 0;
  }
  .callout__label {
    margin: 0 0 0.35em;
    font-family: var(--sans-display);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .callout--important .callout__label {
    color: var(--char);
  }

  /* Slotted MDX content (paragraphs, links, lists) lives outside the scoped
     DOM, so target it through :global() under the wrapper. Tuned smaller and
     tighter than the main reading column. */
  .callout__content :global(> :first-child) {
    margin-top: 0;
  }
  .callout__content :global(> :last-child) {
    margin-bottom: 0;
  }
  .callout__content :global(p) {
    margin: 0 0 0.6em;
    font-family: var(--serif-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--graphite);
  }
  .callout__content :global(a) {
    color: var(--gold-deep);
    border-bottom: 1px solid var(--rule);
    transition: border-color var(--t-fast) var(--ease), color var(--t-fast) var(--ease);
  }
  .callout__content :global(a:hover) {
    color: var(--char);
    border-color: var(--gold-deep);
  }
  .callout__content :global(strong) {
    font-weight: 500;
    color: var(--char);
  }
  .callout__content :global(code) {
    font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
    font-size: 0.86em;
    background: var(--gold-soft);
    padding: 0.12em 0.4em;
    border-radius: 4px;
    color: var(--gold-deep);
  }
</style>
