---
// =====================================================================
// DocsSearch — Cmd/Ctrl-K search modal. The Pagefind index is built from
// the production `dist/` output, so live results only exist in builds;
// in dev the modal shows a graceful "search builds with the site" note.
// All behaviour (open/close, querying, keyboard nav) lives in docs.ts.
// This element is transition:persist'd by DocsLayout.
// =====================================================================
---

<div class="docs-search" data-docs-search hidden>
  <div class="docs-search__backdrop" data-docs-search-close></div>
  <div
    class="docs-search__panel"
    role="dialog"
    aria-modal="true"
    aria-label="Search documentation"
  >
    <div class="docs-search__head">
      <span class="docs-search__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.2-3.2"></path>
        </svg>
      </span>
      <input
        type="search"
        class="docs-search__input"
        data-docs-search-input
        placeholder="Search the documentation…"
        aria-label="Search the documentation"
        autocomplete="off"
        spellcheck="false"
      />
      <button class="docs-search__esc" type="button" data-docs-search-close aria-label="Close search">Esc</button>
    </div>
    <div class="docs-search__results" data-docs-search-results role="listbox" aria-label="Search results">
      <p class="docs-search__status" data-docs-search-status>Type to search the documentation.</p>
    </div>
  </div>
</div>

<style>
  .docs-search {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(60px, 12vh, 140px) var(--gutter) var(--gutter);
  }
  .docs-search[hidden] {
    display: none;
  }
  .docs-search__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 17, 0.34);
    backdrop-filter: blur(2px);
  }
  .docs-search__panel {
    position: relative;
    width: min(620px, 100%);
    max-height: min(70vh, 560px);
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 14px;
    box-shadow: 0 32px 80px -24px rgba(17, 17, 17, 0.5);
    overflow: hidden;
  }
  .docs-search__head {
    display: flex;
    align-items: center;
    gap: 0.7em;
    padding: 14px 16px;
    border-bottom: 1px solid var(--rule-faint);
  }
  .docs-search__icon {
    width: 19px;
    height: 19px;
    flex: 0 0 auto;
    color: var(--gold-deep);
  }
  .docs-search__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .docs-search__input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    font-family: var(--serif-body);
    font-size: 1.15rem;
    color: var(--char);
    outline: none;
  }
  .docs-search__input::placeholder {
    color: var(--graphite);
    opacity: 0.7;
  }
  .docs-search__esc {
    flex: 0 0 auto;
    font-family: var(--sans-display);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--graphite);
    background: var(--gold-soft);
    border: 1px solid var(--rule-faint);
    border-radius: 6px;
    padding: 4px 9px;
    cursor: pointer;
    transition: color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);
  }
  .docs-search__esc:hover {
    color: var(--char);
  }
  .docs-search__results {
    overflow-y: auto;
    padding: 10px;
  }
  .docs-search__status {
    margin: 0;
    padding: 18px 12px 22px;
    font-family: var(--sans);
    font-size: 0.92rem;
    color: var(--graphite);
    text-align: center;
  }

  /* Result items are injected by docs.ts; style them via :global(). */
  .docs-search__results :global(.docs-result) {
    display: block;
    padding: 12px 14px;
    border-radius: 9px;
    cursor: pointer;
    transition: background var(--t-fast) var(--ease);
  }
  .docs-search__results :global(.docs-result:hover),
  .docs-search__results :global(.docs-result.is-active) {
    background: var(--gold-soft);
  }
  .docs-search__results :global(.docs-result__group) {
    font-family: var(--sans-display);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .docs-search__results :global(.docs-result__title) {
    margin: 0.2em 0 0;
    font-family: var(--serif-display);
    font-weight: 400;
    font-size: 1.12rem;
    line-height: 1.2;
    color: var(--char);
  }
  .docs-search__results :global(.docs-result__excerpt) {
    margin: 0.3em 0 0;
    font-family: var(--sans);
    font-size: 0.86rem;
    line-height: 1.45;
    color: var(--graphite);
  }
  .docs-search__results :global(.docs-result__excerpt mark) {
    background: rgba(198, 161, 91, 0.3);
    color: var(--char);
    border-radius: 2px;
    padding: 0 1px;
  }
</style>
