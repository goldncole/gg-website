---
// [1] Hero — the page's <h1>. Text-led on paper, with a faint ghosted
// gold-icon watermark bleeding off the right edge (matches HeroBlock).
---

<section class="section standard-hero" aria-labelledby="standard-hero-heading">
  <img
    class="standard-hero__watermark"
    src="/images/gold-icon.webp"
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />
  <div class="container standard-hero__inner">
    <p class="eyebrow reveal">The Standard</p>

    <h1
      class="display display--xl standard-hero__title reveal"
      id="standard-hero-heading"
      data-reveal-delay="0.05"
    >
      The shared rulebook for the world&rsquo;s gold.
    </h1>

    <p class="standard-hero__subhead reveal" data-reveal-delay="0.1">
      Global Gold defines how approved vault-held bars, on-chain claims, and
      fungible settlement units work together to make allocated physical gold
      globally liquid &mdash; without forcing custody into one issuer.
    </p>

    <div class="standard-hero__actions reveal" data-reveal-delay="0.16">
      <a class="cta--box" href="#layers">Explore the layers</a>
      <a class="cta" href="#modules">See the modules &rarr;</a>
    </div>

    <ul class="standard-hero__trust reveal" data-reveal-delay="0.2" role="list">
      <li>Approved vault custody</li>
      <li>Vault-operated Title Registers</li>
      <li>SMUs backed 1:1 by collateralized claims</li>
    </ul>
  </div>
</section>

<style>
  .standard-hero {
    position: relative;
    overflow: hidden;
    /* extra top padding so the H1 clears the fixed site header */
    padding-top: clamp(140px, 18vh, 220px);
  }
  .standard-hero__inner {
    position: relative;
    z-index: 1;
  }
  .standard-hero__watermark {
    position: absolute;
    z-index: 0;
    top: 50%;
    right: clamp(-120px, -4vw, -40px);
    width: min(48vw, 560px);
    transform: translateY(-50%);
    opacity: 0.06;
    filter: grayscale(1) brightness(0.4);
    pointer-events: none;
  }

  .standard-hero__title {
    margin-top: clamp(20px, 2.6vw, 32px);
    max-width: 16ch;
    text-wrap: balance;
  }
  .standard-hero__subhead {
    margin: clamp(28px, 3.6vw, 44px) 0 0;
    max-width: 62ch;
    font-family: var(--serif-body);
    font-weight: 400;
    font-size: clamp(1.3rem, 1.9vw, 1.7rem);
    line-height: 1.5;
    color: var(--char);
  }

  .standard-hero__actions {
    margin-top: clamp(32px, 4vw, 48px);
    display: flex;
    align-items: center;
    gap: clamp(20px, 3vw, 40px);
    flex-wrap: wrap;
  }

  .standard-hero__trust {
    margin: clamp(40px, 5vw, 64px) 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6em 1.1em;
    font-family: var(--sans-display);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--graphite);
  }
  .standard-hero__trust span {
    position: relative;
  }
  .standard-hero__trust li {
    position: relative;
  }
  .standard-hero__trust li + li::before {
    content: "\00B7";
    margin-right: 1.1em;
    color: var(--gold-deep);
  }

  @media (max-width: 720px) {
    .standard-hero__title {
      max-width: 100%;
    }
    .standard-hero__watermark {
      opacity: 0.04;
    }
    .standard-hero__trust {
      flex-direction: column;
      align-items: flex-start;
    }
    .standard-hero__trust li + li::before {
      content: none;
    }
  }
</style>
