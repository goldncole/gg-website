---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Global Gold — The Global Gold Standard",
  description = "Global market infrastructure for allocated gold. One shared standard for how the world's gold is registered, represented, collateralized, and made liquid.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/images/gold-icon.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <slot />
    <script>
      import "../scripts/motion.ts";
    </script>
  </body>
</html>
