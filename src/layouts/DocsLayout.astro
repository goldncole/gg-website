---
// =====================================================================
// DocsLayout — three-column documentation shell built on Base.astro.
// Fixed SiteHeader (dark ink over the paper ground, white over the
// footer) + sticky DocsSidebar (~280px) + content (~760px) + sticky
// DocsToc rail (~220px) + SiteFooter. A docs subbar (drawer + search
// triggers) appears below the header on mobile. The sidebar and search
// modal are transition:persist'd so they don't flicker/re-scroll when
// navigating between doc pages. Interactions live in src/scripts/docs.ts.
// =====================================================================
import Base from "./Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import DocsSearch from "../components/docs/DocsSearch.astro";

export interface Props {
  title?: string;
  description?: string;
  /** Active entry slug, or null on the docs index. */
  currentSlug?: string | null;
  /** Hide the right-hand TOC rail (e.g. the docs index landing). */
  showToc?: boolean;
}

const { title, description, currentSlug = null, showToc = true } = Astro.props;
---

<Base title={title} description={description}>
  <SiteHeader />

  <div class="docs-page">
    <div class="docs-subbar">
      <button
        class="docs-subbar__btn"
        type="button"
        data-docs-sidebar-toggle
        aria-label="Open documentation menu"
        aria-expanded="false"
        aria-controls="docs-sidebar"
      >
        <span class="docs-subbar__menu-icon" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        Menu
      </button>
      <button
        class="docs-subbar__btn docs-subbar__btn--search"
        type="button"
        data-docs-search-open
        aria-label="Search documentation"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.2-3.2"></path>
        </svg>
      </button>
    </div>

    <div class:list={["docs-shell", { "docs-shell--no-toc": !showToc }]}>
      <DocsSidebar currentSlug={currentSlug} transition:persist="docs-sidebar" />

      <main class="docs-main" id="docs-main" data-pagefind-body>
        <slot />
      </main>

      {
        showToc && (
          <div class="docs-rail">
            <slot name="toc" />
          </div>
        )
      }
    </div>
  </div>

  <SiteFooter />
  <DocsSearch transition:persist="docs-search" />

  <script>
    import "../scripts/docs.ts";
  </script>
</Base>

<style>
  .docs-page {
    --docs-header-h: 78px;
    position: relative;
    z-index: 1;
    background: var(--paper);
    min-height: 60vh;
    padding-top: calc(var(--docs-header-h) + clamp(28px, 4vw, 52px));
    padding-bottom: clamp(72px, 9vw, 120px);
  }

  /* Lock background scroll while the mobile drawer or search modal is open. */
  :global(html.docs-drawer-open) {
    overflow: hidden;
  }

  /* ---- mobile subbar (drawer + search triggers) ---- */
  .docs-subbar {
    display: none;
  }

  .docs-shell {
    max-width: 1440px;
    margin-inline: auto;
    padding-inline: clamp(22px, 4vw, 56px);
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr) 216px;
    gap: clamp(30px, 3.4vw, 60px);
    align-items: start;
  }
  .docs-shell--no-toc {
    grid-template-columns: 280px minmax(0, 1fr);
  }

  .docs-main {
    min-width: 0;
    max-width: 820px;
  }

  .docs-rail {
    position: sticky;
    top: calc(var(--docs-header-h) + 26px);
    align-self: start;
    max-height: calc(100dvh - var(--docs-header-h) - 46px);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* < 1100px: drop the TOC rail. */
  @media (max-width: 1100px) {
    .docs-shell,
    .docs-shell--no-toc {
      grid-template-columns: 264px minmax(0, 1fr);
    }
    .docs-rail {
      display: none;
    }
  }

  /* < 860px: sidebar collapses to a drawer; the subbar provides the toggle. */
  @media (max-width: 860px) {
    .docs-shell,
    .docs-shell--no-toc {
      grid-template-columns: minmax(0, 1fr);
    }
    .docs-subbar {
      position: sticky;
      top: var(--docs-header-h);
      z-index: 50;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: clamp(20px, 4vw, 28px);
      padding: 11px clamp(22px, 5vw, 28px);
      background: color-mix(in srgb, var(--paper) 88%, transparent);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--rule-faint);
    }
    .docs-page {
      padding-top: var(--docs-header-h);
    }
  }

  .docs-subbar__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    padding: 8px 14px;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 9px;
    cursor: pointer;
    font-family: var(--sans-display);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--char);
    transition: border-color var(--t-fast) var(--ease), color var(--t-fast) var(--ease);
  }
  .docs-subbar__btn:hover {
    border-color: var(--gold-deep);
    color: var(--gold-deep);
  }
  .docs-subbar__btn--search {
    margin-left: auto;
    padding: 8px;
    width: 38px;
    height: 38px;
    justify-content: center;
  }
  .docs-subbar__btn--search svg {
    width: 18px;
    height: 18px;
    color: var(--gold-deep);
  }
  .docs-subbar__menu-icon {
    display: inline-flex;
    flex-direction: column;
    gap: 3.5px;
    width: 16px;
  }
  .docs-subbar__menu-icon span {
    height: 1.6px;
    background: currentColor;
  }
</style>
