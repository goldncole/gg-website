    .memo-content p,
    .memo-content li,
    .memo-footnote,
    .memo-confidential,
    .memo-subtitle {
      font-family: "Georgia", "Times New Roman", serif !important;
      color: #000 !important;
    }
    .memo-content p,
    .memo-content li {
      font-size: 10.5pt;
      line-height: 1.5;
    }
    .memo-content strong {
      color: #000 !important;
    }

    .memo-head h1 {
      font-size: 22pt;
      color: #000 !important;
    }
    .memo-content h2 {
      font-size: 15pt;
      color: #000 !important;
    }

    /* Major sections start on a fresh page (keep the summary on page 1). */
    .memo-section {
      break-inside: avoid-page;
    }
    .memo-section + .memo-section {
      break-before: page;
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
    }

    /* Keep tables and quotes intact across page breaks. */
    .memo-table-wrap,
    .memo-quote {
      break-inside: avoid;
      overflow: visible;
    }
    .memo-table {
      font-size: 9pt;
      color: #000 !important;
    }
    .memo-table th,
    .memo-table td {
      border: 0.75pt solid #000 !important;
      background: transparent !important;
      color: #000 !important;
    }
    .memo-table thead th {
      color: #000 !important;
      background: #eee !important;
    }
    .memo-quote {
      border-left: 3pt solid #000;
      background: transparent !important;
      color: #000 !important;
      font-style: italic;
    }

    @page {
      margin: 2cm;
    }
  }
</style>

<script>
  // =================================================================
  // Deal-memo interactions — scroll-spy (IntersectionObserver), smooth
  // anchor scrolling, mobile menu disclosure, and the print trigger.
  // Mirrors the technique in docs.ts; wired per-page via astro:page-load
  // so it survives <ClientRouter /> view-transition swaps.
  // =================================================================
  let memoSpy: IntersectionObserver | null = null;

  function setupMemo() {
    const root = document.querySelector<HTMLElement>("[data-memo]");
    if (!root) {
      memoSpy?.disconnect();
      memoSpy = null;
      return;
    }

    const sections = Array.from(
      root.querySelectorAll<HTMLElement>("[data-memo-section]"),
    );
    const links = Array.from(
      root.querySelectorAll<HTMLAnchorElement>("[data-memo-link]"),
    );

    // ---- scroll-spy ----
    memoSpy?.disconnect();
    memoSpy = null;

    const setActive = (id: string | null) => {
      links.forEach((link) => {
        link.classList.toggle(
          "is-active",
          link.getAttribute("data-target") === id,
        );
      });
    };

    if (sections.length && links.length) {
      const visible = new Set<string>();
      memoSpy = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) visible.add(e.target.id);
            else visible.delete(e.target.id);
          });

          let activeId: string | null = null;
          for (const s of sections) {
            if (visible.has(s.id)) {
              activeId = s.id;
              break;
            }
          }
          // Nothing in the active band → the last section scrolled past.
          if (!activeId) {
            for (const s of sections) {
              if (s.getBoundingClientRect().top < 140) activeId = s.id;
            }
            if (!activeId) activeId = sections[0].id;
          }
          setActive(activeId);
        },
        { rootMargin: "-110px 0px -62% 0px", threshold: 0 },
      );
      sections.forEach((s) => memoSpy!.observe(s));
    }

    // ---- mobile menu disclosure ----
    const menu = root.querySelector<HTMLElement>("[data-memo-menu]");
    const toggle = root.querySelector<HTMLButtonElement>("[data-memo-toggle]");
    const isMenuOpen = () => Boolean(menu?.classList.contains("is-open"));
    const setMenu = (open: boolean) => {
      menu?.classList.toggle("is-open", open);
      toggle?.setAttribute("aria-expanded", String(open));
    };

    // ---- click delegation (guarded so it attaches once per root) ----
    if (!root.dataset.memoWired) {
      root.dataset.memoWired = "1";

      root.addEventListener("click", (e) => {
        const target = e.target as Element | null;
        if (!target) return;

        // Print trigger.
        if (target.closest("[data-memo-print]")) {
          window.print();
          return;
        }

        // Menu toggle (mobile).
        if (target.closest("[data-memo-toggle]")) {
          setMenu(!isMenuOpen());
          return;
        }

        // Section link → smooth-scroll + close the mobile menu.
        const link = target.closest<HTMLAnchorElement>("[data-memo-link]");
        if (link) {
          const id = link.getAttribute("data-target");
          const section = id ? document.getElementById(id) : null;
          if (section) {
            e.preventDefault();
            const reduce = window.matchMedia(
              "(prefers-reduced-motion: reduce)",
            ).matches;
            section.scrollIntoView({
              behavior: reduce ? "auto" : "smooth",
              block: "start",
            });
            history.replaceState(null, "", `#${id}`);
            setActive(id);
          }
          if (window.matchMedia("(max-width: 900px)").matches) setMenu(false);
          return;
        }
      });
    }

    setMenu(false);
  }

  document.addEventListener("astro:page-load", setupMemo);
  document.addEventListener("astro:before-swap", () => {
    memoSpy?.disconnect();
    memoSpy = null;
  });
</script>
