                <tr><td>Collateralization fee (at SMU mint)</td><td>40 bps</td><td>50% vault / 50% OpCo technology slice</td></tr>
                <tr><td>Settlement / title-transfer events</td><td>50 bps</td><td>50% vault / 50% OpCo settlement-rails slice</td></tr>
                <tr><td>Redemption fee (at CCT burn)</td><td>25 bps</td><td>50% vault / 50% OpCo technology slice</td></tr>
                <tr><td>gGold mint/burn — frontend</td><td>10 bps</td><td>OpCo</td></tr>
                <tr><td>gGold mint/burn — protocol</td><td>12.5 bps</td><td>Foundation Treasury</td></tr>
                <tr><td>DEX routing — frontend</td><td>.25 bps of routed volume</td><td>OpCo</td></tr>
