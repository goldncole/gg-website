  .pdf-modal__title {
    font-family: var(--sans-display);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--char);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pdf-modal__tools {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: none;
  }
  .pdf-modal__tool {
    font-family: var(--sans-display);
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    color: var(--gold-deep);
    padding: 6px 10px;
    border-radius: 6px;
    white-space: nowrap;
    transition: background var(--t-fast) var(--ease);
  }
  .pdf-modal__tool:hover {
    background: rgba(216, 210, 200, 0.28);
  }
  .pdf-modal__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--graphite);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    transition: background var(--t-fast) var(--ease),
      color var(--t-fast) var(--ease);
  }
  .pdf-modal__close:hover {
    background: rgba(216, 210, 200, 0.28);
    color: var(--char);
  }
  .pdf-modal__frame-wrap {
    flex: 1;
    min-height: 0;
    background: #525659;
  }
  .pdf-modal__frame {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  html.pdf-lock,
  html.pdf-lock body {
    overflow: hidden;
  }
  /* While a document preview is open, hide the fixed site header — it sits in a
     higher stacking context and would otherwise overlap and intercept clicks on
     the modal's top bar (e.g. the close button). */
  html.pdf-lock :global([data-site-header]) {
    display: none;
  }

  @media (max-width: 640px) {
    .pdf-modal {
      padding: 0;
    }
    .pdf-modal__dialog {
      width: 100%;
      height: 100%;
      border: 0;
      border-radius: 0;
    }
  }

  /* ---- Print button ---- */
  .memo-print {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    padding: 10px 16px;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 10px;
    cursor: pointer;
    font-family: var(--sans-display);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--char);
    transition: border-color var(--t-fast) var(--ease),
      color var(--t-fast) var(--ease);
  }
  .memo-print:hover {
    border-color: var(--gold-deep);
    color: var(--gold-deep);
  }
  .memo-print svg {
    width: 16px;
    height: 16px;
    color: var(--gold-deep);
  }
  .memo-menu .memo-print {
    position: sticky;
    bottom: 0;
    margin-top: clamp(22px, 2.4vw, 30px);
    width: 100%;
    justify-content: center;
    /* Paper mask so scrolled nav links don't crowd the pinned button. */
    box-shadow: 0 -10px 10px 6px var(--paper);
  }

  .memo-content__toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: clamp(20px, 3vw, 32px);
  }
  /* On desktop the sidebar carries the print button; the inline one is the
     mobile-friendly duplicate at the top of the content column. */
  .memo-print--inline {
    display: none;
  }

  /* ---- RIGHT: memo content ---- */
  .memo-content {
    min-width: 0;
    max-width: 780px;
  }

  .memo-printhead {
    display: none;
  }

  .memo-section {
    scroll-margin-top: calc(var(--memo-header-h) + 28px);
  }
  .memo-section + .memo-section {
    margin-top: clamp(48px, 6vw, 80px);
    padding-top: clamp(40px, 5vw, 64px);
    border-top: 1px solid var(--rule-faint);
  }

  .memo-head {
    margin-bottom: clamp(8px, 2vw, 18px);
  }
  .memo-head .eyebrow {
    margin-bottom: 1em;
  }
  .memo-head h1 {
    margin: 0;
  }
  .memo-subtitle {
    margin-top: 0.7em;
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    line-height: 1.28;
    color: var(--graphite);
  }

  .memo-content :is(h2) {
    margin-bottom: clamp(0.7em, 1.6vw, 1em);
  }

  .memo-content p {
    font-family: var(--sans);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--graphite);
    margin: 0 0 1.05em;
  }
  .memo-content strong {
    color: var(--char);
    font-weight: 500;
  }

  /* ---- Blockquotes ---- */
  .memo-quote {
    margin: clamp(1.2em, 2.4vw, 1.8em) 0;
    padding: clamp(16px, 2vw, 22px) clamp(20px, 2.4vw, 28px);
    border-left: 3px solid var(--gold);
    background: rgba(216, 210, 200, 0.14);
    border-radius: 0 var(--radius-img) var(--radius-img) 0;
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    line-height: 1.34;
    color: var(--char);
  }
  .memo-quote--epigraph {
    font-style: italic;
  }
  .memo-quote strong {
    font-weight: 400;
    color: var(--char);
  }

  /* ---- Lists ---- */
  .memo-list {
    margin: 0 0 1.1em;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85em;
  }
  .memo-list li {
    font-family: var(--sans);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--graphite);
    padding-left: 1.7em;
    position: relative;
  }
  .memo-list:not(.memo-list--numbered) li::before {
    content: "";
    position: absolute;
    left: 0.35em;
    top: 0.62em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold);
  }
  .memo-list--numbered {
    counter-reset: memo-counter;
  }
  .memo-list--numbered li {
    counter-increment: memo-counter;
  }
  .memo-list--numbered li::before {
    content: counter(memo-counter) ".";
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--sans-display);
    font-weight: 500;
    font-size: 0.95em;
    color: var(--gold-deep);
  }

  /* ---- Tables ---- */
  .memo-table-wrap {
    margin: clamp(1.2em, 2.4vw, 1.8em) 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-img);
  }
  .memo-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--sans);
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--graphite);
  }
  .memo-table th,
  .memo-table td {
    text-align: left;
    padding: 11px 16px;
    border: 1px solid var(--rule);
    vertical-align: top;
  }
  .memo-table thead th {
    font-family: var(--sans-display);
    font-weight: 500;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gold-deep);
    background: rgba(216, 210, 200, 0.16);
    white-space: nowrap;
  }
  .memo-table tbody th[scope="row"] {
    font-family: var(--sans-display);
    font-weight: 500;
    color: var(--char);
    background: rgba(216, 210, 200, 0.08);
  }
  .memo-table tbody tr:nth-child(even) td {
    background: rgba(216, 210, 200, 0.05);
  }
  .memo-table strong {
    color: var(--char);
    font-weight: 600;
  }

  /* Two-column borderless "deal terms" list. */
  .memo-table--terms th,
  .memo-table--terms td {
    border-left: 0;
    border-right: 0;
  }
  .memo-table--terms th[scope="row"] {
    width: 42%;
    background: transparent;
  }
  .memo-table--terms td {
    background: transparent !important;
    color: var(--char);
  }

  .memo-table--risks th[scope="row"] {
    width: 34%;
  }

  /* ---- footnote / confidential ---- */
  .memo-hr {
    height: 1px;
    background: var(--rule);
    border: 0;
    margin: clamp(2em, 4vw, 3em) 0 clamp(1.4em, 2.4vw, 2em);
  }
  .memo-footnote,
  .memo-confidential {
    font-family: var(--serif-body);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--graphite);
  }
  .memo-confidential {
    margin-top: 1.2em;
    color: var(--gold-deep);
  }

  /* ===================================================================
     MOBILE — collapse the left menu into a sticky disclosure above the
     content (mirrors the docs mobile pattern).
     =================================================================== */
  @media (max-width: 900px) {
    .memo-shell {
      grid-template-columns: minmax(0, 1fr);
      gap: 0;
    }

    .memo-menu {
      position: sticky;
      top: var(--memo-header-h);
      z-index: 40;
      max-height: none;
      overflow: visible;
      margin-bottom: clamp(24px, 5vw, 34px);
      background: color-mix(in srgb, var(--paper) 92%, transparent);
      backdrop-filter: blur(8px);
      border: 1px solid var(--rule);
      border-radius: var(--radius-img);
    }

    .memo-menu__toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 13px 16px;
      background: transparent;
      border: 0;
      cursor: pointer;
      font-family: var(--sans-display);
      font-size: 0.74rem;
      font-weight: 500;
      letter-spacing: var(--track-eyebrow);
      text-transform: uppercase;
      color: var(--gold-deep);
    }
    .memo-menu__toggle-chev {
      font-size: 1.1rem;
      line-height: 1;
      transition: transform var(--t-fast) var(--ease);
    }
    .memo-menu.is-open .memo-menu__toggle-chev {
      transform: rotate(90deg);
    }

    .memo-menu__panel {
      display: none;
      padding: 4px 16px 16px;
    }
    .memo-menu.is-open .memo-menu__panel {
      display: block;
    }
    .memo-menu__eyebrow {
      display: block;
    }
    /* First group header sits flush under the "Sections" toggle. */
    .memo-menu__panel > .memo-menu__eyebrow:first-child {
      margin-top: 2px;
    }
    .memo-menu .memo-print {
      position: static;
      box-shadow: none;
      margin-top: 18px;
    }

    .memo-content {
      max-width: none;
    }
    .memo-content__toolbar {
      display: none;
    }
    .memo-print--inline {
      display: inline-flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .memo-menu__toggle-chev {
      transition: none;
    }
  }

  /* ===================================================================
     PRINT — clean printable / PDF memo document.
     Hide all site chrome + the on-screen menu; render content full-width
     in a legible serif; avoid breaking tables; page-break major sections.
     =================================================================== */
  @media print {
    /* Hide site chrome, hero, menu, and the print buttons. */
    :global([data-site-header]),
    :global([data-site-footer]),
    :global([data-hero]),
    .memo-menu,
    .memo-content__toolbar,
    .memo-print {
      display: none !important;
    }

    /* Neutralize the pinned-hero offset so content starts at the top. */
    :global(.page-over--pinned) {
      margin-top: 0 !important;
    }
    :global(html.footer-reveal .page-over) {
      margin-bottom: 0 !important;
      min-height: 0 !important;
    }

    .memo {
      padding: 0;
    }
    .memo-shell {
      display: block;
      max-width: none;
      margin: 0;
      padding: 0;
      gap: 0;
    }
    .memo-content {
      max-width: none;
      width: 100%;
    }

    /* Printed title header at the top of the document. */
    .memo-printhead {
      display: block;
      margin-bottom: 20pt;
      padding-bottom: 8pt;
      border-bottom: 1pt solid #000;
      font-family: "Georgia", serif;
      font-size: 10pt;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #000;
    }

    /* Body copy prints in the same sans face used on screen; titles stay serif. */
    .memo-content,
    .memo-content p,
    .memo-content li,
    .memo-footnote,
    .memo-confidential {
      font-family: var(--sans) !important;
      color: #000 !important;
    }
    .memo-subtitle {
      color: #000 !important;
    }
    .memo-content p,
    .memo-content li {
      font-size: 10.5pt;
      line-height: 1.5;
    }
    .memo-content strong {
      color: #000 !important;
    }

    .memo-head h1 {
      font-size: 22pt;
      color: #000 !important;
    }
    .memo-content h2 {
      font-size: 15pt;
      color: #000 !important;
    }

    /* Major sections start on a fresh page (keep the summary on page 1). */
    .memo-section {
      break-inside: avoid-page;
    }
    .memo-section + .memo-section {
      break-before: page;
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
    }

    /* Keep tables and quotes intact across page breaks. */
    .memo-table-wrap,
    .memo-quote {
      break-inside: avoid;
      overflow: visible;
    }
    .memo-table {
      font-size: 9pt;
      color: #000 !important;
    }
    .memo-table th,
    .memo-table td {
      border: 0.75pt solid #000 !important;
      background: transparent !important;
      color: #000 !important;
    }
    .memo-table thead th {
      color: #000 !important;
      background: #eee !important;
    }
    .memo-quote {
      border-left: 3pt solid #000;
      background: transparent !important;
      color: #000 !important;
      font-style: italic;
    }

    @page {
      margin: 2cm;
    }
  }
</style>

<script>
  // =================================================================
  // Deal-memo interactions — scroll-spy (IntersectionObserver), smooth
  // anchor scrolling, mobile menu disclosure, and the print trigger.
  // Mirrors the technique in docs.ts; wired per-page via astro:page-load
  // so it survives <ClientRouter /> view-transition swaps.
  // =================================================================
  let memoSpy: IntersectionObserver | null = null;
  let memoKeydownWired = false;

  function setupMemo() {
    const root = document.querySelector<HTMLElement>("[data-memo]");
    if (!root) {
      memoSpy?.disconnect();
      memoSpy = null;
      return;
    }

    const sections = Array.from(
      root.querySelectorAll<HTMLElement>("[data-memo-section]"),
    );
    const links = Array.from(
      root.querySelectorAll<HTMLAnchorElement>("[data-memo-link]"),
    );

    // ---- scroll-spy ----
    memoSpy?.disconnect();
    memoSpy = null;

    const setActive = (id: string | null) => {
      links.forEach((link) => {
        link.classList.toggle(
          "is-active",
          link.getAttribute("data-target") === id,
        );
      });
    };

    if (sections.length && links.length) {
      const visible = new Set<string>();
      memoSpy = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) visible.add(e.target.id);
            else visible.delete(e.target.id);
          });

          let activeId: string | null = null;
          for (const s of sections) {
            if (visible.has(s.id)) {
              activeId = s.id;
              break;
            }
          }
          // Nothing in the active band → the last section scrolled past.
          if (!activeId) {
            for (const s of sections) {
              if (s.getBoundingClientRect().top < 140) activeId = s.id;
            }
            if (!activeId) activeId = sections[0].id;
          }
          setActive(activeId);
        },
        { rootMargin: "-110px 0px -62% 0px", threshold: 0 },
      );
      sections.forEach((s) => memoSpy!.observe(s));
    }

    // ---- mobile menu disclosure ----
    const menu = root.querySelector<HTMLElement>("[data-memo-menu]");
    const toggle = root.querySelector<HTMLButtonElement>("[data-memo-toggle]");
    const isMenuOpen = () => Boolean(menu?.classList.contains("is-open"));
    const setMenu = (open: boolean) => {
      menu?.classList.toggle("is-open", open);
      toggle?.setAttribute("aria-expanded", String(open));
    };

    // ---- PDF preview modal ----
    // Query the DOM at call time (not via cached refs) so open/close keep
    // working after Astro live-reloads / view transitions swap the modal node.
    const openPdf = (url: string, title: string) => {
      const modal = document.querySelector<HTMLElement>("[data-pdf-modal]");
      const frame = modal?.querySelector<HTMLIFrameElement>("[data-pdf-frame]");
      if (!modal || !frame || !url) return;
      // View-only preview: hide the built-in PDF viewer toolbar (which exposes
      // download / print / save) and its side panes via the URL fragment.
      frame.src = url + "#toolbar=0&navpanes=0";
      const modalTitle = modal.querySelector<HTMLElement>("[data-pdf-title]");
      if (modalTitle) modalTitle.textContent = title;
      modal.hidden = false;
      document.documentElement.classList.add("pdf-lock");
    };
    const closePdf = () => {
      const modal = document.querySelector<HTMLElement>("[data-pdf-modal]");
      if (!modal) return;
      modal.hidden = true;
      const frame = modal.querySelector<HTMLIFrameElement>("[data-pdf-frame]");
      if (frame) frame.src = "about:blank";
      document.documentElement.classList.remove("pdf-lock");
    };

    // Close on Escape. Attached once to the persistent document (view
    // transitions swap body content but keep document), and re-reads the DOM
    // at event time so it never holds a stale reference.
    if (!memoKeydownWired) {
      memoKeydownWired = true;
      document.addEventListener("keydown", (e) => {
        if (e.key !== "Escape") return;
        const m = document.querySelector<HTMLElement>("[data-pdf-modal]");
        if (!m || m.hidden) return;
        m.hidden = true;
        const f = m.querySelector<HTMLIFrameElement>("[data-pdf-frame]");
        if (f) f.src = "about:blank";
        document.documentElement.classList.remove("pdf-lock");
      });
    }

    // ---- click delegation (guarded so it attaches once per root) ----
    if (!root.dataset.memoWired) {
      root.dataset.memoWired = "1";

      root.addEventListener("click", (e) => {
        const target = e.target as Element | null;
        if (!target) return;

        // Print trigger.
        if (target.closest("[data-memo-print]")) {
          window.print();
          return;
        }

        // Menu toggle (mobile).
        if (target.closest("[data-memo-toggle]")) {
          setMenu(!isMenuOpen());
          return;
        }

        // PDF modal: close (backdrop click or ✕ button).
        if (target.closest("[data-pdf-close]")) {
          closePdf();
          return;
        }

        // PDF modal: open a Supporting Docs file in-page instead of a new tab.
        const pdfLink = target.closest<HTMLAnchorElement>("[data-pdf]");
        if (pdfLink) {
          e.preventDefault();
          openPdf(
            pdfLink.getAttribute("href") || "",
            pdfLink.getAttribute("data-pdf-title") || "Document",
          );
          if (window.matchMedia("(max-width: 900px)").matches) setMenu(false);
          return;
        }

        // Section link → smooth-scroll + close the mobile menu.
        const link = target.closest<HTMLAnchorElement>("[data-memo-link]");
        if (link) {
          const id = link.getAttribute("data-target");
          const section = id ? document.getElementById(id) : null;
          if (section) {
            e.preventDefault();
            const reduce = window.matchMedia(
              "(prefers-reduced-motion: reduce)",
            ).matches;
            section.scrollIntoView({
              behavior: reduce ? "auto" : "smooth",
              block: "start",
            });
            history.replaceState(null, "", `#${id}`);
            setActive(id);
          }
          if (window.matchMedia("(max-width: 900px)").matches) setMenu(false);
          return;
        }
      });
    }

    setMenu(false);
  }

  document.addEventListener("astro:page-load", setupMemo);
  document.addEventListener("astro:before-swap", () => {
    memoSpy?.disconnect();
    memoSpy = null;
  });
</script>
