---
// =====================================================================
// Journal article route — renders a `journal` collection entry through
// the ArticlePage template. Drafts are excluded from the production build.
// =====================================================================
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import ArticlePage from "../../layouts/templates/ArticlePage.astro";
import type { RelatedItem } from "../../components/blocks/RelatedGrid.astro";

export const getStaticPaths = (async () => {
  const entries = await getCollection("journal", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );

  return entries.map((entry) => {
    // Up to three other posts as "related", newest first.
    const related: RelatedItem[] = entries
      .filter((e) => e.id !== entry.id)
      .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
      .slice(0, 3)
      .map((e) => ({
        eyebrow: e.data.category,
        title: e.data.title,
        blurb: e.data.dek,
        href: `/journal/${e.id}/`,
      }));

    return { params: { slug: entry.id }, props: { entry, related } };
  });
}) satisfies GetStaticPaths;

const { entry, related } = Astro.props;
const { Content } = await render(entry);

// Reading time from the raw body (~200 wpm).
const words = (entry.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const minutes = Math.max(1, Math.round(words / 200));
const readingTime = `${minutes} min read`;
---

<ArticlePage
  content={{
    title: entry.data.title,
    dek: entry.data.dek,
    category: entry.data.category,
    tags: entry.data.tags,
    author: entry.data.author,
    authorBio: entry.data.authorBio,
    publishDate: entry.data.publishDate,
    readingTime,
    heroImage: entry.data.heroImage,
    heroImageAlt: entry.data.heroImageAlt,
    related: { items: related },
  }}
>
  <Content />
</ArticlePage>
