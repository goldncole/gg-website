---
// =====================================================================
// Journal index — lists published entries as editorial cards, newest
// first. Built on InnerPage + PageHero + the content collection.
// =====================================================================
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import InnerPage from "../../layouts/InnerPage.astro";
import PageHero from "../../components/blocks/PageHero.astro";

const entries = (
  await getCollection("journal", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  )
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const fmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<InnerPage
  title="The Journal — Global Gold"
  description="Perspectives on allocated gold, market infrastructure, and the Global Gold Standard."
>
  <PageHero
    eyebrow="The Journal"
    title="Perspectives on the standard."
    lede="Essays and explainers on allocated gold, market infrastructure, and how the Global Gold Standard works."
  />

  <section class="section journal-list" aria-label="Journal articles">
    <div class="container">
      <ul class="journal-grid">
        {
          entries.map((entry, i) => (
            <li class="journal-card reveal" data-reveal-delay={(0.04 + (i % 3) * 0.04).toFixed(2)}>
              <a class="journal-card__link" href={`/journal/${entry.id}/`}>
                {entry.data.heroImage && (
                  <figure class="journal-card__media">
                    <Image
                      src={entry.data.heroImage}
                      alt={entry.data.heroImageAlt ?? entry.data.title}
                      widths={[320, 480, 640]}
                      sizes="(max-width: 540px) 100vw, (max-width: 1000px) 50vw, 33vw"
                    />
                  </figure>
                )}
                <div class="journal-card__body">
                  <p class="journal-card__eyebrow">{entry.data.category}</p>
                  <h2 class="journal-card__title">{entry.data.title}</h2>
                  <p class="journal-card__dek">{entry.data.dek}</p>
                  <p class="journal-card__date">
                    <time datetime={entry.data.publishDate.toISOString()}>
                      {fmt.format(entry.data.publishDate)}
                    </time>
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</InnerPage>

<style>
  .journal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(32px, 3vw, 52px) clamp(24px, 2vw, 36px);
  }
  .journal-card {
    display: flex;
  }
  .journal-card__link {
    display: flex;
    flex-direction: column;
    flex: 1;
    color: inherit;
  }
  .journal-card__media {
    margin: 0;
    border-radius: var(--radius-img);
    overflow: hidden;
    background: var(--stone);
    aspect-ratio: 3 / 2;
  }
  .journal-card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease);
  }
  .journal-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    margin-top: clamp(18px, 1.8vw, 24px);
    padding-top: clamp(18px, 1.8vw, 24px);
    border-top: 1px solid var(--rule-faint);
  }
  .journal-card__eyebrow {
    font-family: var(--sans-display);
    font-size: var(--t-eyebrow);
    font-weight: 500;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .journal-card__title {
    margin: clamp(10px, 1.2vw, 14px) 0 clamp(10px, 1.1vw, 14px);
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(1.4rem, 1.9vw, 1.8rem);
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: var(--char);
    transition: color var(--t-base) var(--ease);
  }
  .journal-card__dek {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.5;
    color: var(--graphite);
  }
  .journal-card__date {
    margin: clamp(16px, 1.6vw, 22px) 0 0;
    font-family: var(--sans-display);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--graphite);
  }
  .journal-card__link:hover .journal-card__media :global(img) {
    transform: scale(1.04);
  }
  .journal-card__link:hover .journal-card__title {
    color: var(--gold-deep);
  }

  @media (max-width: 1000px) {
    .journal-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 540px) {
    .journal-grid {
      grid-template-columns: 1fr;
    }
  }
  /* Lift dek to a comfortable mobile reading floor (~17px); desktop stays
     at 0.98rem. */
  @media (max-width: 768px) {
    .journal-card__dek { font-size: 1.0625rem; }
  }
</style>
