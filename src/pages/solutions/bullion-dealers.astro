    lede: "Tokenize a bar and reach a continuous, global, on-chain market — without shipping metal, surrendering custody, or losing the client.",
    columns: 3,
    items: [
      {
        eyebrow: "Global reach",
        title: "Sell into worldwide demand",
        body: "Tokenize an allocated bar and collateralize it into Standard Metal Units, then sell into a continuous, 24/7 on-chain market. Your inventory reaches buyers far beyond the local counter — without a bar ever crossing a border.",
      },
      {
        eyebrow: "Velocity",
        title: "Turn inventory, don't just hold it",
