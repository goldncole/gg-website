---
// =====================================================================
// PAGE — Solutions · Bullion Dealers (uses SolutionPage template).
// Copy v2 — conversion + repositioning pass. Core thesis, validated by
// research: a dealer's inventory is capped by the local buyer pool and
// today's local bid, while margins (~1%) are crushed by carry costs
// (financing ~9-10% vs retail spreads of 3-5%). Regional premiums are
// large and persistent (India +6-8%, Dubai-Mumbai ~$400/oz, China
// +$10-30/oz) but walled off by duties, export licensing, logistics,
// and capital controls. The Standard lets a dealer tokenize allocated
// bars and sell into continuous, global, 24/7 on-chain liquidity —
// reaching worldwide demand WITHOUT shipping metal across a border,
// accelerating inventory turnover and freeing trapped working capital.
// De-emphasizes the P2P premium-bar marketplace (architecturally
// de-prioritized); keeps bar-identity preservation via CCTs as a
// supporting reassurance, not the spine. Verb is "collateralize" (not
// "lock"). Voice: Network/Protocol, no "we" = LLC. Swap the hero
// `/images/*` placeholder for final dealer/inventory photography.
// =====================================================================
import SolutionPage from "../../layouts/templates/SolutionPage.astro";
import type { SolutionPageContent } from "../../layouts/templates/SolutionPage.astro";

const content: SolutionPageContent = {
  meta: {
