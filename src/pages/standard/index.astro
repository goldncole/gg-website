---
import Base from "../../layouts/Base.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import StandardHero from "../../components/standard/StandardHero.astro";
import Definition from "../../components/standard/Definition.astro";
import Layers from "../../components/standard/Layers.astro";
import RoundTrip from "../../components/standard/RoundTrip.astro";
import StandardModules from "../../components/standard/StandardModules.astro";
import StandardSolves from "../../components/standard/StandardSolves.astro";
import ClosingCta from "../../components/standard/ClosingCta.astro";
---

<Base
  title="The Standard — Global Gold"
  description="The Global Gold Standard defines how approved vault-held bars, on-chain claims, and fungible settlement units work together to make allocated physical gold globally liquid."
>
  <SiteHeader />
  <div class="page-over">
    <main>
      <StandardHero />
      <Definition />
      <Layers />
      <RoundTrip />
      <StandardModules />
      <StandardSolves />
      <ClosingCta />
    </main>
  </div>
  <SiteFooter />
</Base>

<style>
  /* This page uses a normal (non-pinned) hero, so the content sits at the top
     of the document. The .page-over>main wrapper keeps the shared Auwa-style
     inset hairline separators between sibling sections. The SiteFooter sits
     outside .page-over so it can be pinned behind for the shared scroll
     reveal (see global.css `.footer-reveal`). */
  .page-over {
    position: relative;
    z-index: 1;
    background: var(--paper);
  }
</style>
