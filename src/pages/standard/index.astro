---
// Above-the-fold mirrors the homepage / Council: a full-bleed pinned hero image
// (no text overlay) that the page content scrolls up over (see InnerPage
// pinnedHero + HeroMark + motion.ts). StandardHero becomes the first panel in
// the reveal, riding up over the pinned image on the paper background.
import InnerPage from "../../layouts/InnerPage.astro";
import StandardHero from "../../components/standard/StandardHero.astro";
import Definition from "../../components/standard/Definition.astro";
import Layers from "../../components/standard/Layers.astro";
import RoundTrip from "../../components/standard/RoundTrip.astro";
import StandardModules from "../../components/standard/StandardModules.astro";
import StandardSolves from "../../components/standard/StandardSolves.astro";
import ClosingCta from "../../components/standard/ClosingCta.astro";
---

<InnerPage
  title="The Standard — Global Gold"
  description="The Global Gold Standard defines how approved vault-held bars, on-chain claims, and fungible settlement units work together to make allocated physical gold globally liquid."
  pinnedHero={{
    src: "/images/the-standard-hero.png",
    alt: "An open rulebook on a lectern in a sunlit marble hall, with the Global Gold emblem on the wall behind it.",
  }}
>
  <StandardHero />
  <Definition />
  <Layers />
  <RoundTrip />
  <StandardModules />
  <StandardSolves />
  <ClosingCta />
</InnerPage>
